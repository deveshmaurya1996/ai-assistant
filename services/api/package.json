{
  "name": "@ai-assistant/api",
  "version": "1.0.0",
  "description": "API Gateway for AI Assistant",
  "main": "src/index.ts",
  "scripts": {
    "dev": "node -r @ai-assistant/telemetry/register dist/index.js",
    "serve": "node -r @ai-assistant/telemetry/register dist/index.js",
    "predev": "node ../../node_modules/typescript/bin/tsc",
    "build": "node ../../node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "test:integration": "node -r @ai-assistant/config/register -r ts-node/register src/verify_integration.ts"
  },
  "dependencies": {
    "@ai-assistant/auth": "workspace:*",
    "@ai-assistant/config": "workspace:*",
    "@ai-assistant/database": "workspace:*",
    "@ai-assistant/events": "workspace:*",
    "@ai-assistant/feature-flags": "workspace:*",
    "@ai-assistant/tool-schema": "workspace:*",
    "@ai-assistant/integrations": "workspace:*",
    "@ai-assistant/telemetry": "workspace:*",
    "@ai-assistant/types": "workspace:*",
    "@ai-assistant/workflows": "workspace:*",
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "better-auth": "^1.2.0",
    "bullmq": "^5.77.1",
    "dotenv": "^17.4.2",
    "@whiskeysockets/baileys": "~6.7.23",
    "fastify": "^5.8.5",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.5",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3"
  }
}
