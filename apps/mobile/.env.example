# Expo public env (bundled at build time). Copy to `.env` in this folder.
#
# Android emulator → host machine:
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
#
# iOS simulator:
# EXPO_PUBLIC_API_URL=http://localhost:3000
#
# Physical device (replace with your PC's LAN IP):
# EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
#
# Google OAuth (requires GOOGLE_CLIENT_ID/SECRET in root .env + API running)
# EXPO_PUBLIC_GOOGLE_AUTH_ENABLED=true
