{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "src/components/themed-*.tsx",
    "src/components/web-badge.tsx",
    "src/components/hint-row.tsx",
    "src/components/external-link.tsx",
    "src/components/ui/collapsible.tsx",
    "src/hooks/use-theme.ts"
  ]
}
