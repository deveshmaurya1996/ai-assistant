{
  "name": "@ai-assistant/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@ai-assistant/icons": "workspace:*",
    "@ai-assistant/sdk": "workspace:*",
    "@ai-assistant/types": "workspace:*",
    "@better-auth/expo": "1.6.11",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~56.0.13",
    "@expo/ui": "~56.0.15",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.6.2",
    "@siteed/audio-studio": "^3.2.0",
    "@siteed/audio-ui": "^1.1.1",
    "@tanstack/react-query": "^5.100.13",
    "better-auth": "1.6.11",
    "expo": "~56.0.8",
    "expo-application": "~56.0.3",
    "expo-audio": "~56.0.11",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.16",
    "expo-camera": "~56.0.7",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-document-picker": "^56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-picker": "^56.0.15",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-media-library": "^56.0.6",
    "expo-network": "~56.0.4",
    "expo-notifications": "~56.0.8",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.3",
    "expo-sharing": "^56.0.16",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.4",
    "expo-updates": "~56.0.6",
    "expo-video": "~56.1.2",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.16.0",
    "moti": "^0.30.0",
    "react": "19.2.3",
    "react-async-hook": "^4.0.0",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-country-picker-modal": "^2.0.0",
    "react-native-drawer-layout": "^4.2.4",
    "react-native-enriched-markdown": "^0.6.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.8.3",
    "remend": "^1.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eas-cli": "^16.32.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "postinstall": "node scripts/patch-country-picker.mjs",
    "dev": "node scripts/expo-cli.mjs start --web",
    "build": "echo \"Expo app — use expo export for production builds\"",
    "start": "node scripts/expo-cli.mjs start",
    "adb-reverse": "node scripts/adb-reverse.mjs",
    "android": "node ../../scripts/ports.mjs sync && node scripts/adb-reverse.mjs && node scripts/expo-cli.mjs prebuild --platform android && node scripts/expo-cli.mjs run:android",
    "ios": "node scripts/expo-cli.mjs run:ios",
    "web": "node scripts/expo-cli.mjs start --web",
    "lint": "node scripts/expo-cli.mjs lint",
    "eas-build-post-install": "cd ../.. && pnpm --filter @ai-assistant/types build && pnpm --filter @ai-assistant/sdk build",
    "release:sync": "node ../../scripts/sync-mobile-release.mjs",
    "release:sync:eas": "node ../../scripts/sync-mobile-release.mjs --from-eas",
    "eas:build:android:prod": "node scripts/sync-root-easignore.mjs && pnpm exec eas build -p android --profile production && node ../../scripts/sync-mobile-release.mjs --from-eas",
    "eas:build:android:preview": "node scripts/sync-root-easignore.mjs && pnpm exec eas build -p android --profile preview && node ../../scripts/sync-mobile-release.mjs --from-eas",
    "eas:update:production": "pnpm exec eas update --channel production --environment production",
    "eas:update:preview": "pnpm exec eas update --channel preview --environment preview"
  },
  "private": true,
  "expo": {
    "autolinking": {
      "searchPaths": ["../../node_modules", "./node_modules"]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "@siteed/audio-studio",
          "@siteed/audio-ui",
          "expo-modules-jsi"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
