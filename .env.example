# =============================================================================
# AI Assistant Platform — monorepo environment (copy to `.env` at repo root)
#   pnpm env:setup
# =============================================================================
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL (infra/docker/compose.core.yml)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://ai_assistant:ai_assistant@localhost:5432/ai_assistant

# -----------------------------------------------------------------------------
# API Gateway (Fastify @ services/api)
# -----------------------------------------------------------------------------
API_PORT=3000
AI_SERVICE_URL=http://localhost:8000

# API rate limits (per IP / per user sliding windows — see services/api/src/lib/rate-limit.ts)
# RATE_LIMIT_IP_GLOBAL_MAX=300
# RATE_LIMIT_IP_AUTH_MAX=40
# RATE_LIMIT_USER_API_MAX=500
# RATE_LIMIT_USER_AI_MAX=80
# RATE_LIMIT_SOCKET_CHAT_MAX=60
# RATE_LIMIT_VOICE_TRANSCRIBE_MAX=30
# RATE_LIMIT_VOICE_SPEAK_MAX=60
BETTER_AUTH_SECRET=dev-secret-change-me-min-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Model routing — Gemini 3.1 Pro / GPT-5.5 / Claude 4 for chat; Pollinations fallback
TEXT_MODEL=gemini/gemini-3.1-pro-preview
TEXT_FALLBACK_MODEL=pollinations/openai
PRIMARY_MODEL=gemini/gemini-3.1-pro-preview
FALLBACK_MODEL=pollinations/openai
# Speech-to-text / TTS / image primaries (OpenAI), Pollinations fallback
TRANSCRIPTION_MODEL=whisper-1
TRANSCRIPTION_FALLBACK_MODEL=pollinations/whisper-1
# batch (default) | deepgram | realtime — streaming adapters fall back to batch without keys
VOICE_STT_PROVIDER=batch
DEEPGRAM_API_KEY=
SPEECH_MODEL=tts-1
SPEECH_VOICE=nova
SPEECH_FALLBACK_MODEL=pollinations/openai-audio
IMAGE_MODEL=dall-e-3
IMAGE_FALLBACK_MODEL=pollinations/flux
# Provider API keys (server-side only — never embed in mobile APK)
# Tier 1: OPENAI_API_KEY + GEMINI_API_KEY — premium chat, realtime/live voice (Phase 4)
# Tier 2: + ANTHROPIC_API_KEY — long reasoning
# Tier 3: POLLINATIONS_API_KEY — fallback chat/STT/TTS only (NOT duplex voice)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Voice mode: auto | classic | gemini-live | openai-realtime (auto picks live when keys exist)
VOICE_MODE=auto
# Pollinations (https://enter.pollinations.ai) — Tier-3 fallback only
POLLINATIONS_MODEL=openai
POLLINATIONS_TRANSCRIPTION_MODEL=whisper-1
POLLINATIONS_SPEECH_MODEL=openai-audio
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_BASE_URL=https://gen.pollinations.ai
POLLINATIONS_API_KEY=

# -----------------------------------------------------------------------------
# Redis & Qdrant (docker compose)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# -----------------------------------------------------------------------------
# OpenTelemetry (export to otel-collector when monitoring profile is up)
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME_API=ai-assistant-api
OTEL_SERVICE_NAME_AI=ai-assistant-ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# -----------------------------------------------------------------------------
# Langfuse (optional — tilt up -- --services=full)
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3003

# -----------------------------------------------------------------------------
# Web (Next.js dashboard)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------
PRISMA_LOG_QUERIES=false

# -----------------------------------------------------------------------------
# Mobile (Expo) — also copy apps/mobile/.env.example → apps/mobile/.env
# EXPO_PUBLIC_* is bundled into the app (see apps/mobile/.env.example).
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_API_URL=http://localhost:3000
