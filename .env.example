# =============================================================================
# LOCAL development — copy to `.env` (or run: pnpm env:setup)
# Tilt defaults: gateway :3000, ai :8000, cognitive :3013, tool-runtime :3011,
# skill-runtime :3014
# =============================================================================
NODE_ENV=development

# --- Core URLs (gateway is the public API) ---
API_PORT=3000
API_PUBLIC_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000
COGNITIVE_RUNTIME_URL=http://localhost:3013
TOOL_RUNTIME_URL=http://localhost:3011
SKILL_RUNTIME_URL=http://localhost:3014

# --- Database (Docker: pnpm docker:up) ---
DATABASE_URL=postgresql://ai_assistant:ai_assistant@localhost:5432/ai_assistant

# --- Auth & internal service mesh ---
BETTER_AUTH_SECRET=dev-secret-change-me-min-32-characters-long
INTEGRATION_ENCRYPTION_KEY=dev-integration-key-change-me
INTERNAL_SERVICE_TOKEN=dev-internal-token

# --- Google OAuth ---
# Sign-in: GOOGLE_*  |  Integrations (Gmail/Calendar/Drive): GOOGLE_INTEGRATION_*
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=
MOBILE_DEEP_LINK=ai-assistant://integrations

# --- Storage ---
STORAGE_BACKEND=local
UPLOAD_DIR=./data/uploads
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Redis & Qdrant (Docker: pnpm docker:up) ---
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- AI provider keys (ai-runtime + cognitive-runtime) ---
NVIDIA_API_KEY=
NVIDIA_SECOND_API_KEY=
GROQ_API_KEY=
POLLINATIONS_API_KEY=

# --- Chat / orchestrator ---
ORCHESTRATOR_TIMEOUT_MS=30000
ORCHESTRATOR_STREAM_TIMEOUT=45
ORCHESTRATOR_CANCEL_ON_DISCONNECT=true

# --- Voice ---
VOICE_MODE=classic
VOICE_STT_PROVIDER=batch
SPEECH_VOICE=alloy

# --- Web & mobile (local) ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- WhatsApp (runs inside gateway locally) ---
WHATSAPP_BRIDGE_URL=http://localhost:3000/internal/whatsapp
WHATSAPP_AUTH_DIR=data/wa-auth

# --- Mobile update policy (gateway GET /mobile/version) ---
MOBILE_ANDROID_PLAY_STORE_URL=
MOBILE_ANDROID_APK_URL=
MOBILE_UPDATE_URL_MODE=auto

# --- Expo push (gateway) ---
EXPO_ACCESS_TOKEN=

# --- Misc ---
OTEL_ENABLED=false
PRISMA_LOG_QUERIES=false
