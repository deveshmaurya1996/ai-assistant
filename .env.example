# =============================================================================
# AI Assistant Platform — monorepo environment (copy to `.env` at repo root)
#   pnpm env:setup
# =============================================================================
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL (infra/docker/compose.core.yml)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://ai_assistant:ai_assistant@localhost:5432/ai_assistant

# -----------------------------------------------------------------------------
# API Gateway (Fastify @ services/gateway) — Tilt defaults API_PORT=3050
# -----------------------------------------------------------------------------
API_PORT=3050
GATEWAY_URL=http://localhost:3050
API_URL=http://localhost:3050
AI_SERVICE_URL=http://localhost:8050
AI_PORT=8050

# API rate limits (per IP / per user sliding windows — see services/api/src/lib/rate-limit.ts)
# RATE_LIMIT_IP_GLOBAL_MAX=300
# RATE_LIMIT_IP_AUTH_MAX=40
# RATE_LIMIT_USER_API_MAX=500
# RATE_LIMIT_USER_AI_MAX=80
# RATE_LIMIT_SOCKET_CHAT_MAX=60
# RATE_LIMIT_VOICE_TRANSCRIBE_MAX=30
# RATE_LIMIT_VOICE_SPEAK_MAX=60
BETTER_AUTH_SECRET=dev-secret-change-me-min-32-characters-long
BETTER_AUTH_URL=http://localhost:3050

# Google OAuth — Better Auth sign-in (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google OAuth — Connect Apps (Gmail, Calendar, Drive) — separate from sign-in above.
# Create a dedicated OAuth client in Google Cloud Console (not the Better Auth login client).
# Authorized redirect URI (required):
#   {API_PUBLIC_URL}/integrations/google/callback
# Example: http://localhost:3050/integrations/google/callback
# Enable Gmail API, Google Calendar API, and Google Drive API for that project.
# Users stay logged into the app; Connect Apps only requests API scopes.
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=
GOOGLE_INTEGRATION_REDIRECT_URI=
API_PUBLIC_URL=http://localhost:3050
# Uploaded chat attachments — Cloudflare R2 (primary) or local disk fallback
# From dashboard URL https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com/{R2_BUCKET_NAME}
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ENDPOINT=
# Create under R2 → Manage R2 API Tokens (S3-compatible access key + secret)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
UPLOAD_DIR=./data/uploads
# r2 | local — uses R2 when account, bucket, and both keys are set (or STORAGE_BACKEND=r2)
STORAGE_BACKEND=r2
# Deep link after OAuth (must match Expo scheme in apps/mobile/app.config.ts)
MOBILE_DEEP_LINK=ai-assistant://integrations

# Provider API keys (server-side only — never embed in mobile APK)
# Routing: config/ai-models.yaml — NVIDIA primary (integrate + ai.api rerank), Pollinations fallback.
NVIDIA_API_KEY=
GROQ_API_KEY=
POLLINATIONS_API_KEY=
ORCHESTRATOR_TIMEOUT_MS=35000
ORCHESTRATOR_STREAM_TIMEOUT=45
ORCHESTRATOR_CANCEL_ON_DISCONNECT=true

# Optional: override path to ai-models.yaml (default: config/ai-models.yaml at repo root)
# AI_MODELS_CONFIG=

# Voice: Whisper STT (Pollinations) → integrate LLM → Magpie or Pollinations TTS
# Set POLLINATIONS_API_KEY for transcription, TTS, and image generation (Pollinations Flux).
# Image generation uses Pollen credits; quota errors show retry guidance in chat.
# Optional ISO-639-1 hint for Whisper (e.g. en). Leave unset for auto-detect.
# TRANSCRIBE_LANGUAGE=en
# nemotron-voicechat full-duplex (early access) is not implemented — see voice_router FULL_DUPLEX stub
VOICE_MODE=classic
# batch (default) | deepgram | realtime — streaming STT adapters
VOICE_STT_PROVIDER=batch
DEEPGRAM_API_KEY=
SPEECH_VOICE=nova
# Voice STT converts uploads to 16 kHz mono WAV via ffmpeg (required on ai-runtime host).
# Windows winget: winget install Gyan.FFmpeg — ai-runtime auto-discovers WinGet install if not on PATH.
# Optional override: folder containing ffmpeg.exe and ffprobe.exe
# FFMPEG_BIN=C:\Users\you\AppData\Local\Microsoft\WinGet\Packages\...\ffmpeg-8.x-full_build\bin
# Magpie TTS (Speech NIM HTTP) — set when you have zeroshot access on build.nvidia.com
# NVIDIA_MAGPIE_TTS_HTTP_URL=https://<your-nim-host>
# NVIDIA_MAGPIE_PROMPT_PATH=services/ai-runtime/assets/voice/default_magpie_prompt.wav

# -----------------------------------------------------------------------------
# Redis & Qdrant (docker compose)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
# Ops: RAG_ENABLED=false disables KB retrieval entirely (ingest still runs).
# RAG_RETRIEVAL_MODE=smart (default) searches only when the message implies memory; use always for debug.
# RAG_ROUTER_MODE=heuristic (default) or llm for retrieve-or-not routing.
# MEMORY_PRESTREAM_BUDGET_MS=300 — hybrid stream-first memory (status then answer).
# RAG_TIMEOUT_SECONDS=5 — cognitive → ai-runtime episodic search cap.
# MEMORY_EXTRACTION_ENABLED=true (default) — extract curated facts when the turn likely has durable user info.
# MEMORY_EPISODIC_POSTGRES=false (default) — do not store CONVERSATION rows in Postgres; episodic recall uses Qdrant only.
# MEMORY_CLEANUP_CONVERSATION_ROWS=false — set true once to delete legacy CONVERSATION rows from Postgres on gateway start.
# CHAT_HISTORY_LIMIT=20 — latest N messages per chat (chronological).
# CONVERSATIONAL_HISTORY_LIMIT=10 — shorter DB fetch for hi/how are you (faster replies).
# SESSION_FILE_AUTO_HYDRATE=true — re-load session files on follow-ups (e.g. "check the file").
# Attachment / document-mode latency
# ROUTING_QUERY_MAX_CHARS=512
# ATTACHMENT_USER_QUERY_MAX_CHARS=2000
# ATTACHMENT_FILE_CONTEXT_MAX_CHARS=8000
# ATTACHMENT_EXCERPT_STREAM_MAX=6000
# ATTACHMENT_EXCERPT_SKIP_RETRIEVAL_CHARS=2000
# ATTACHMENT_HISTORY_LIMIT=8
# MEMORY_FACT_LIMIT=5
# RAG_ENABLED=true

# -----------------------------------------------------------------------------
# OpenTelemetry (export to otel-collector when monitoring profile is up)
# -----------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_SERVICE_NAME_API=ai-assistant-api
OTEL_SERVICE_NAME_AI=ai-assistant-ai
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# -----------------------------------------------------------------------------
# Langfuse (optional — tilt up -- --services=full)
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3003

# -----------------------------------------------------------------------------
# Web (Next.js dashboard @ :3001 — uses next.config rewrites to gateway)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3050

# -----------------------------------------------------------------------------
# Platform services (local dev — start before Connect Apps → WhatsApp)
# -----------------------------------------------------------------------------
# Baileys lives in gateway — tool-runtime calls this internal route
WHATSAPP_BRIDGE_URL=http://localhost:3050/internal/whatsapp
# Relative to services/gateway (not repo root)
WHATSAPP_AUTH_DIR=data/wa-auth
WHATSAPP_OP_TIMEOUT_MS=90000
INTERNAL_SERVICE_TOKEN=dev-internal-token
# TOOL_RUNTIME_URL=http://localhost:3011
# SKILL_RUNTIME_URL=http://localhost:3014
COGNITIVE_RUNTIME_URL=http://localhost:3013
AI_ORCHESTRATOR_URL=http://localhost:3013
# SKILLS_ROOT=skills
# INGESTION_ENGINE_URL=http://localhost:3012
# TEMPORAL_ENABLED=false
# TEMPORAL_ADDRESS=localhost:7233

# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------
PRISMA_LOG_QUERIES=false

# -----------------------------------------------------------------------------
# Mobile (Expo) — also copy apps/mobile/.env.example → apps/mobile/.env
# EXPO_PUBLIC_* is bundled into the app (see apps/mobile/.env.example).
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_API_URL=http://localhost:3000
