
NODE_ENV=development

# --- Public API (auth, REST, Socket.IO, in-process tool/capability runtimes) ---
API_PORT=3000
API_PUBLIC_URL=http://localhost:3000

# --- Intelligence (Python FastAPI — planner, chat, voice, RAG) ---
INTELLIGENCE_UPSTREAM_URL=http://localhost:8000

# --- Database & cache (Docker: pnpm docker up) ---
DATABASE_URL=postgresql://ai_assistant:ai_assistant@localhost:5432/ai_assistant
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Auth & internal mesh ---
BETTER_AUTH_SECRET=dev-secret-change-me-min-32-characters-long
INTEGRATION_ENCRYPTION_KEY=dev-integration-key-change-me
INTERNAL_SERVICE_TOKEN=dev-internal-token

# --- Google OAuth ---
# Sign-in: GOOGLE_*  |  Integrations (Gmail/Calendar/Drive): GOOGLE_INTEGRATION_*
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=
MOBILE_DEEP_LINK=ai-assistant://integrations

# --- Storage ---
STORAGE_BACKEND=local
UPLOAD_DIR=./data/uploads
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- AI provider keys ---
NVIDIA_API_KEY=
NVIDIA_SECOND_API_KEY=
GROQ_API_KEY=
POLLINATIONS_API_KEY=

# --- Workers (gateway BullMQ) ---
INGESTION_CONCURRENCY=2
WORKFLOW_CONCURRENCY=2
SCHEDULER_CONCURRENCY=2
MEMORY_CONCURRENCY=2

# --- Chat / orchestrator ---
ORCHESTRATOR_STREAM_TIMEOUT=30
ORCHESTRATOR_CANCEL_ON_DISCONNECT=true

# --- Voice ---
VOICE_MODE=classic
VOICE_STT_PROVIDER=batch
SPEECH_VOICE=alloy

# --- Client apps (must match API_PUBLIC_URL) ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- WhatsApp session files (bridge runs inside gateway) ---
WHATSAPP_AUTH_DIR=data/wa-auth

# --- Mobile update policy (gateway GET /mobile/version) ---
MOBILE_ANDROID_PLAY_STORE_URL=
MOBILE_ANDROID_APK_URL=
MOBILE_UPDATE_URL_MODE=auto
