# =============================================================================
# LOCAL development — copy to `.env` (pnpm env:setup)
# Production: copy `.env.production.example` → `.env.production`
# =============================================================================
NODE_ENV=development

# --- Database (Docker: pnpm docker:up) ---
DATABASE_URL=postgresql://ai_assistant:ai_assistant@localhost:5432/ai_assistant

# --- API Gateway (local) ---
API_PORT=3000
API_PUBLIC_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000
COGNITIVE_RUNTIME_URL=http://localhost:3013

BETTER_AUTH_SECRET=dev-secret-change-me-min-32-characters-long
INTEGRATION_ENCRYPTION_KEY=dev-integration-key-change-me
INTERNAL_SERVICE_TOKEN=dev-internal-token

# Better Auth sign-in (optional if using email/password only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Gmail/Calendar/Drive — falls back to GOOGLE_* when unset
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=
MOBILE_DEEP_LINK=ai-assistant://integrations

# --- R2 uploads (optional locally; use STORAGE_BACKEND=local to skip R2) ---
STORAGE_BACKEND=local
UPLOAD_DIR=./data/uploads
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- Redis & Qdrant (Docker: pnpm docker:up) ---
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- AI provider keys (ai-runtime + cognitive) ---
NVIDIA_API_KEY=
GROQ_API_KEY=
POLLINATIONS_API_KEY=

ORCHESTRATOR_TIMEOUT_MS=30000
ORCHESTRATOR_STREAM_TIMEOUT=45
ORCHESTRATOR_CANCEL_ON_DISCONNECT=true

VOICE_MODE=classic
VOICE_STT_PROVIDER=batch
SPEECH_VOICE=alloy

# --- Web & mobile (local) ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Optional platform services ---
WHATSAPP_BRIDGE_URL=http://localhost:3000/internal/whatsapp
WHATSAPP_AUTH_DIR=data/wa-auth
OTEL_ENABLED=false
PRISMA_LOG_QUERIES=false
