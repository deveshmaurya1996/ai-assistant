# =============================================================================
# AI Assistant Platform — monorepo environment (copy to `.env` at repo root)
#   pnpm env:setup
# =============================================================================
NODE_ENV=development

# -----------------------------------------------------------------------------
# PostgreSQL (matches infra/docker/docker-compose.yml)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://ai_assistant:ai_assistant@localhost:5432/ai_assistant

# -----------------------------------------------------------------------------
# API Gateway (Fastify @ services/api)
# -----------------------------------------------------------------------------
API_PORT=3000
AI_SERVICE_URL=http://localhost:8000
BETTER_AUTH_SECRET=dev-secret-change-me-min-32-characters-long
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Model routing — Gemini 3.1 Pro / GPT-5.5 / Claude 4 for chat; Pollinations fallback
TEXT_MODEL=gemini/gemini-3.1-pro-preview
TEXT_FALLBACK_MODEL=pollinations/openai
PRIMARY_MODEL=gemini/gemini-3.1-pro-preview
FALLBACK_MODEL=pollinations/openai
# Speech-to-text / TTS / image primaries (OpenAI), Pollinations fallback
TRANSCRIPTION_MODEL=whisper-1
TRANSCRIPTION_FALLBACK_MODEL=pollinations/openai
SPEECH_MODEL=tts-1
SPEECH_VOICE=alloy
SPEECH_FALLBACK_MODEL=pollinations/openai-audio
IMAGE_MODEL=dall-e-3
IMAGE_FALLBACK_MODEL=pollinations/flux
# Provider API keys
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Pollinations (https://enter.pollinations.ai) — fallback only
POLLINATIONS_MODEL=openai
POLLINATIONS_SPEECH_MODEL=openai-audio
POLLINATIONS_IMAGE_MODEL=flux
POLLINATIONS_BASE_URL=https://gen.pollinations.ai
POLLINATIONS_API_KEY=

# -----------------------------------------------------------------------------
# Redis & Qdrant (docker compose)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------
PRISMA_LOG_QUERIES=false

# -----------------------------------------------------------------------------
# Mobile (Expo) — also copy apps/mobile/.env.example → apps/mobile/.env
# EXPO_PUBLIC_* is bundled into the app; use your machine LAN IP on physical devices.
# -----------------------------------------------------------------------------
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
