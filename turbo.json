{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "API_PORT",
    "AI_SERVICE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "REDIS_URL",
    "QDRANT_URL",
    "PRIMARY_MODEL",
    "FALLBACK_MODEL",
    "GEMINI_API_KEY",
    "OPENAI_API_KEY",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "EXPO_PUBLIC_API_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "cache": false
    }
  }
}
