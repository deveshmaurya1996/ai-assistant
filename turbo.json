{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "API_PORT",
    "API_PUBLIC_URL",
    "INTELLIGENCE_UPSTREAM_URL",
    "BETTER_AUTH_SECRET",
    "REDIS_URL",
    "QDRANT_URL",
    "PRIMARY_MODEL",
    "FALLBACK_MODEL",
    "GEMINI_API_KEY",
    "OPENAI_API_KEY",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "EXPO_PUBLIC_API_URL",
    "NEXT_PUBLIC_API_URL",
    "OTEL_ENABLED",
    "OTEL_SERVICE_NAME_API",
    "OTEL_SERVICE_NAME_AI",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_EXPORTER_OTLP_PROTOCOL",
    "LANGFUSE_PUBLIC_KEY",
    "LANGFUSE_SECRET_KEY",
    "LANGFUSE_HOST"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^build"]
    },
    "test:integration": {
      "cache": false
    }
  }
}
