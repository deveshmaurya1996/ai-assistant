{
  "name": "@ai-assistant/database",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prepare": "node scripts/prisma-generate.mjs",
    "build": "node scripts/prisma-generate.mjs --lenient && node ../../node_modules/typescript/bin/tsc",
    "db:generate": "node scripts/prisma-generate.mjs",
    "db:push": "node ../../node_modules/prisma/build/index.js db push",
    "db:migrate": "node ../../node_modules/prisma/build/index.js migrate dev",
    "db:migrate:deploy": "node ../../node_modules/prisma/build/index.js migrate deploy",
    "db:seed": "node ../../node_modules/prisma/build/index.js db execute --file prisma/seed-providers.sql --schema prisma/schema.prisma",
    "studio": "node ../../node_modules/prisma/build/index.js studio --browser none --hostname 127.0.0.1 --port 5566"
  },
  "dependencies": {
    "@ai-assistant/config": "workspace:*",
    "@prisma/client": "^6.2.0"
  },
  "devDependencies": {
    "@prisma/config": "^6.2.0",
    "@types/node": "^22.10.0",
    "dotenv": "^17.4.2",
    "prisma": "^6.2.0",
    "typescript": "latest"
  }
}
