{
  "name": "@ai-assistant/database",
  "version": "1.0.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node ../../scripts/prisma-generate.mjs && node ../../node_modules/typescript/bin/tsc",
    "db:generate": "node ../../scripts/prisma-generate.mjs",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio --browser none --hostname 127.0.0.1"
  },
  "dependencies": {
    "@ai-assistant/config": "workspace:*",
    "@prisma/client": "^6.2.0"
  },
  "devDependencies": {
    "@prisma/config": "^6.2.0",
    "@types/node": "^22.10.0",
    "dotenv": "^17.4.2",
    "prisma": "^6.2.0",
    "typescript": "latest"
  }
}
