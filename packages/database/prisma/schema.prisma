generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  settings      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  chatSessions  ChatSession[]
  agentConfigs  AgentConfig[]
  memoryItems   MemoryItem[]
  automations   Automation[]
  connections   UserConnection[]
  workflows     Workflow[]
  reminders     Reminder[]
  toolInvocations ToolInvocation[]
  fileAssets    FileAsset[]
  notes         UserNote[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

enum ChatSessionKind {
  TEXT
  VOICE
}

model ChatSession {
  id        String          @id @default(uuid())
  userId    String
  title     String?
  kind      ChatSessionKind @default(TEXT)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId])
}

model Message {
  id            String      @id @default(uuid())
  chatSessionId String
  role          Role
  content       String
  metadata      Json?
  createdAt     DateTime    @default(now())

  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  notes         UserNote[]

  @@index([chatSessionId])
}

model AgentConfig {
  id          String   @id @default(uuid())
  userId      String
  agentType   String
  credentials Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserNote {
  id              String   @id @default(uuid())
  userId          String
  title           String
  content         String
  sourceMessageId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceMessage Message? @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)

  @@unique([userId, sourceMessageId])
  @@index([userId])
  @@index([userId, updatedAt])
  @@index([userId, sourceMessageId])
}

model MemoryItem {
  id          String     @id @default(uuid())
  userId      String
  type        MemoryType
  content     String
  metadata    Json?
  embeddingId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

model Automation {
  id          String           @id @default(uuid())
  userId      String
  name        String
  trigger     Json
  action      Json
  schedule    String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  runs        AutomationRun[]

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AutomationRun {
  id           String           @id @default(uuid())
  automationId String
  status       AutomationStatus
  result       Json?
  startedAt    DateTime         @default(now())
  completedAt  DateTime?

  automation   Automation       @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
}

enum Role {
  USER
  ASSISTANT
  SYSTEM
}

enum MemoryType {
  PREFERENCE
  FACT
  CONVERSATION
  TASK
  BEHAVIOR
}

enum AutomationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ConnectionStatus {
  PENDING
  ACTIVE
  ERROR
  DISCONNECTED
}

enum ToolInvocationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum ReminderStatus {
  PENDING
  FIRED
  CANCELLED
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model IntegrationProvider {
  id          String   @id
  name        String
  authType    String
  scopes      String[]
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  connections UserConnection[]
}

model UserConnection {
  id                   String           @id @default(uuid())
  userId               String
  providerId           String
  status               ConnectionStatus @default(PENDING)
  encryptedCredentials String?
  scopes               String[]
  metadata             Json?
  lastSyncAt           DateTime?
  expiresAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider             IntegrationProvider  @relation(fields: [providerId], references: [id])
  indexedResources     IndexedResource[]
  toolInvocations      ToolInvocation[]

  @@index([userId])
  @@index([providerId])
}

model IndexedResource {
  id           String   @id @default(uuid())
  connectionId String
  provider     String
  resourceType String
  externalId   String
  title        String?
  snippet      String?
  mimeType     String?
  url          String?
  modifiedAt   DateTime?
  embeddingId  String?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  connection   UserConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, externalId])
  @@index([connectionId])
  @@index([provider])
}

model FileAsset {
  id           String   @id @default(uuid())
  userId       String
  filename     String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  checksum     String?
  indexedAt    DateTime?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ToolInvocation {
  id             String               @id @default(uuid())
  userId         String
  connectionId   String?
  executionId    String               @unique
  toolName       String
  args           Json
  result         Json?
  status         ToolInvocationStatus @default(PENDING)
  source         String
  chatSessionId  String?
  confirmed      Boolean              @default(false)
  error          String?
  startedAt      DateTime             @default(now())
  completedAt    DateTime?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  connection     UserConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([executionId])
}

model Reminder {
  id        String         @id @default(uuid())
  userId    String
  fireAt    DateTime
  payload   Json
  status    ReminderStatus @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fireAt])
}

model Workflow {
  id        String   @id @default(uuid())
  userId    String
  name      String
  trigger   Json
  conditions Json    @default("[]")
  actions   Json
  retries   Json?
  rollback  Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs      WorkflowRun[]

  @@index([userId])
}

model WorkflowRun {
  id         String            @id @default(uuid())
  workflowId String
  status     WorkflowRunStatus @default(PENDING)
  steps      Json?
  error      String?
  startedAt  DateTime          @default(now())
  completedAt DateTime?

  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}
