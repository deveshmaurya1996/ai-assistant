{
  "name": "ai-assistant-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/postinstall.mjs",
    "catalog:generate": "node packages/catalog-codegen/scripts/generate.mjs",
    "catalog:validate": "node packages/catalog-codegen/scripts/validate.mjs",
    "build": "pnpm catalog:generate && pnpm catalog:validate && pnpm exec turbo run build --filter=./packages/* --filter=./services/gateway --filter=./services/tool-runtime --filter=./services/capability-runtime",
    "dev": "node scripts/ports.mjs up",
    "dev:down": "tilt down",
    "dev:gateway": "node scripts/with-env.mjs node scripts/dev.mjs serve gateway",
    "dev:ai-runtime": "node scripts/with-env.mjs node scripts/dev.mjs serve ai-runtime",
    "dev:voice-gateway": "pnpm --filter @ai-assistant/types build && node scripts/with-env.mjs node scripts/dev.mjs serve voice-gateway",
    "dev:web": "pnpm --filter @ai-assistant/web dev",
    "lint": "pnpm exec turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test:integration": "pnpm --filter @ai-assistant/gateway test:integration",
    "db:migrate": "pnpm --filter @ai-assistant/database db:migrate",
    "db:migrate:deploy": "pnpm --filter @ai-assistant/database db:migrate:deploy",
    "docker": "node scripts/docker.mjs",
    "verify": "node scripts/verify.mjs",
    "verify:docker": "node scripts/verify-docker.mjs",
    "mobile:android": "pnpm --filter @ai-assistant/mobile android",
    "mobile:release": "pnpm --filter @ai-assistant/mobile release:sync",
    "mobile:eas": "node scripts/mobile-eas.mjs",
    "mobile:apk": "pnpm --filter @ai-assistant/mobile build:apk:local"
  },
  "dependencies": {
    "turbo": "latest",
    "typescript": "~6.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "is-unicode-supported": "^2.1.0",
    "prettier": "latest"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "uuid": "^14.0.0",
      "@expo/metro-runtime": "~56.0.13",
      "react-async-hook": "4.0.0"
    },
    "patchedDependencies": {
      "@siteed/audio-studio@3.2.0": "patches/@siteed__audio-studio@3.2.0.patch",
      "expo-modules-core@56.0.14": "patches/expo-modules-core@56.0.14.patch"
    }
  }
}
