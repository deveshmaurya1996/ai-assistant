# =============================================================================
# PRODUCTION — copy to `.env.production` (gitignored). Fill secrets.
# On Render: paste each service block into that service's Environment tab.
# Canonical gateway URL: API_PUBLIC_URL (do not duplicate GATEWAY_URL / API_URL).
# =============================================================================
NODE_ENV=production

# =============================================================================
# ai-assistant-gateway — paste this full block
# =============================================================================
API_PORT=10000
API_PUBLIC_URL=https://ai-assistant-462r.onrender.com
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
REDIS_URL=rediss://default:PASSWORD@UPSTASH_HOST:6379
BETTER_AUTH_SECRET=GENERATE_32_PLUS_CHARS
INTEGRATION_ENCRYPTION_KEY=GENERATE_DIFFERENT_32_PLUS_CHARS
INTERNAL_SERVICE_TOKEN=GENERATE_RANDOM_TOKEN
AI_SERVICE_URL=https://ai-assistant-ai.onrender.com
COGNITIVE_RUNTIME_URL=https://ai-assistant-cognitive.onrender.com
TOOL_RUNTIME_URL=https://ai-assistant-tool-runtime.onrender.com
SKILL_RUNTIME_URL=https://ai-assistant-skill-runtime.onrender.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=
MOBILE_DEEP_LINK=ai-assistant://integrations
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
ORCHESTRATOR_TIMEOUT_MS=30000
ORCHESTRATOR_STREAM_TIMEOUT=45
ORCHESTRATOR_CANCEL_ON_DISCONNECT=true
NEXT_PUBLIC_API_URL=https://ai-assistant-462r.onrender.com
WHATSAPP_BRIDGE_URL=https://ai-assistant-462r.onrender.com/internal/whatsapp
WHATSAPP_AUTH_DIR=data/wa-auth
MOBILE_ANDROID_PLAY_STORE_URL=
MOBILE_ANDROID_APK_URL=
MOBILE_UPDATE_URL_MODE=auto
EXPO_ACCESS_TOKEN=
OTEL_ENABLED=false
PRISMA_LOG_QUERIES=false

# =============================================================================
# ai-assistant-cognitive — paste subset (Python)
# =============================================================================
# API_PUBLIC_URL=https://ai-assistant-462r.onrender.com
# AI_SERVICE_URL=https://ai-assistant-ai.onrender.com
# INTERNAL_SERVICE_TOKEN=same-as-gateway
# TOOL_RUNTIME_URL=https://ai-assistant-tool-runtime.onrender.com
# SKILL_RUNTIME_URL=https://ai-assistant-skill-runtime.onrender.com
# ORCHESTRATOR_STREAM_TIMEOUT=45
# NVIDIA_API_KEY=
# NVIDIA_SECOND_API_KEY=
# GROQ_API_KEY=
# POLLINATIONS_API_KEY=

# =============================================================================
# ai-assistant-ai — paste subset (Python)
# =============================================================================
QDRANT_URL=https://YOUR_CLUSTER.region.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=
NVIDIA_API_KEY=
NVIDIA_SECOND_API_KEY=
GROQ_API_KEY=
POLLINATIONS_API_KEY=
VOICE_MODE=classic
VOICE_STT_PROVIDER=batch
SPEECH_VOICE=alloy
OTEL_ENABLED=false

# =============================================================================
# ai-assistant-tool-runtime — paste subset (Node)
# Build: npx pnpm@9.0.0 install --frozen-lockfile && npx pnpm@9.0.0 run build:tool-runtime
# Start: pnpm run start:tool-runtime
# Health: /health
# =============================================================================
# SKIP_INSTALL_DEPS=true
# NODE_ENV=production
# DATABASE_URL=same-as-gateway
# INTEGRATION_ENCRYPTION_KEY=same-as-gateway
# INTERNAL_SERVICE_TOKEN=same-as-gateway
# API_PUBLIC_URL=https://ai-assistant-462r.onrender.com
# GOOGLE_INTEGRATION_CLIENT_ID=same-as-gateway
# GOOGLE_INTEGRATION_CLIENT_SECRET=same-as-gateway

# =============================================================================
# ai-assistant-skill-runtime — paste subset (Node)
# Build: npx pnpm@9.0.0 install --frozen-lockfile && npx pnpm@9.0.0 run build:skill-runtime
# Start: pnpm run start:skill-runtime
# Health: /health
# =============================================================================
# SKIP_INSTALL_DEPS=true
# NODE_ENV=production
# TOOL_RUNTIME_URL=https://ai-assistant-tool-runtime.onrender.com
