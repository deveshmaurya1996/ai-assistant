# =============================================================================
# PRODUCTION — copy to `.env.production` or paste into Render env vars.
# Single Render web service (root Dockerfile + supervisord).
# Health: GET /health on API_PUBLIC_URL
#
# Memory: the combined Python + Node container needs ~700MB+ under load (litellm,
# agent turns). Render Free (512MB) will OOM — use Starter (2GB) or higher.
# Dockerfile defaults disable startup warmups and cap Node heap to reduce pressure.
# =============================================================================
NODE_ENV=production

# --- Public API ---
API_PORT=10000
API_PUBLIC_URL=https://YOUR-PLATFORM.onrender.com

# --- Intelligence (same container, internal only) ---
INTELLIGENCE_UPSTREAM_URL=http://127.0.0.1:8000

# --- Database & cache (managed services) ---
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
REDIS_URL=rediss://default:PASSWORD@UPSTASH_HOST:6379
QDRANT_URL=https://YOUR_CLUSTER.region.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=

# --- Auth & internal mesh ---
BETTER_AUTH_SECRET=GENERATE_32_PLUS_CHARS
INTEGRATION_ENCRYPTION_KEY=GENERATE_DIFFERENT_32_PLUS_CHARS
INTERNAL_SERVICE_TOKEN=GENERATE_RANDOM_TOKEN

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=
MOBILE_DEEP_LINK=ai-assistant://integrations

# --- Storage (production: R2) ---
STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# --- AI provider keys ---
NVIDIA_API_KEY=
NVIDIA_SECOND_API_KEY=
GROQ_API_KEY=
POLLINATIONS_API_KEY=

# --- Workers (keep at 1 on small Render instances) ---
INGESTION_CONCURRENCY=1
WORKFLOW_CONCURRENCY=1
SCHEDULER_CONCURRENCY=1
MEMORY_CONCURRENCY=1

# --- Memory tuning (Dockerfile sets these; override if on a larger plan) ---
WARM_EMBEDDER_ON_STARTUP=false
WARM_AGENT_MODULES=false
NODE_OPTIONS=--max-old-space-size=192

# --- Chat / orchestrator ---
ORCHESTRATOR_STREAM_TIMEOUT=30
ORCHESTRATOR_CANCEL_ON_DISCONNECT=true
HEALTH_PROBE_ON_STARTUP=false

# --- Voice ---
VOICE_MODE=classic
VOICE_STT_PROVIDER=batch
SPEECH_VOICE=alloy

# --- Web dashboard (if built separately; match API_PUBLIC_URL) ---
NEXT_PUBLIC_API_URL=https://YOUR-PLATFORM.onrender.com

# --- WhatsApp ---
WHATSAPP_AUTH_DIR=data/wa-auth

# --- Mobile (EAS builds use apps/mobile/.env.production) ---
MOBILE_ANDROID_PLAY_STORE_URL=
MOBILE_ANDROID_APK_URL=
MOBILE_UPDATE_URL_MODE=auto
EXPO_ACCESS_TOKEN=

# --- Observability (optional) ---
OTEL_ENABLED=false
PRISMA_LOG_QUERIES=false
