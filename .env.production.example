# =============================================================================
# PRODUCTION (Render + Neon + Upstash + Qdrant Cloud)
# Copy to `.env.production` and fill secrets. Gitignored — never commit.
# On Render: paste the same keys into each service's Environment tab.
# =============================================================================
NODE_ENV=production

# --- Render: ai-assistant-gateway ---
API_PORT=10000
API_PUBLIC_URL=https://ai-assistant-462r.onrender.com
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
REDIS_URL=rediss://default:PASSWORD@UPSTASH_HOST:6379

BETTER_AUTH_SECRET=GENERATE_32_PLUS_CHARS
INTEGRATION_ENCRYPTION_KEY=GENERATE_DIFFERENT_32_PLUS_CHARS
INTERNAL_SERVICE_TOKEN=GENERATE_RANDOM_TOKEN

AI_SERVICE_URL=https://ai-assistant-ai.onrender.com
COGNITIVE_RUNTIME_URL=https://ai-assistant-cognitive.onrender.com
TOOL_RUNTIME_URL=https://ai-assistant-tool-runtime.onrender.com
SKILL_RUNTIME_URL=https://ai-assistant-skill-runtime.onrender.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=
MOBILE_DEEP_LINK=ai-assistant://integrations

# Mobile app version policy (gateway GET /mobile/version)
# Version + Android versionCode auto-sync from apps/mobile/release-manifest.json
# (updated after EAS builds via sync-mobile-release.mjs). Override only if needed:
# MOBILE_LATEST_VERSION=1.0.0
# MOBILE_MIN_VERSION=1.0.0
# MOBILE_MIN_ANDROID_VERSION_CODE=1
MOBILE_ANDROID_PLAY_STORE_URL=
MOBILE_ANDROID_APK_URL=
MOBILE_UPDATE_URL_MODE=auto

STORAGE_BACKEND=r2
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

ORCHESTRATOR_TIMEOUT_MS=30000
ORCHESTRATOR_STREAM_TIMEOUT=45
ORCHESTRATOR_CANCEL_ON_DISCONNECT=true

# --- Render: ai-assistant-tool-runtime ---
# Env: SKIP_INSTALL_DEPS=true, NODE_VERSION=22, DATABASE_URL, INTEGRATION_ENCRYPTION_KEY,
#      INTERNAL_SERVICE_TOKEN, API_PUBLIC_URL, GOOGLE_INTEGRATION_* (same as gateway)
# Build:  npx pnpm@9.0.0 install --frozen-lockfile && npx pnpm@9.0.0 run build:tool-runtime
# Start:  pnpm run start:tool-runtime
# Health: /health
#
# --- Render: ai-assistant-skill-runtime ---
# Env: SKIP_INSTALL_DEPS=true, NODE_VERSION=22, TOOL_RUNTIME_URL
# Build:  npx pnpm@9.0.0 install --frozen-lockfile && npx pnpm@9.0.0 run build:skill-runtime
# Start:  pnpm run start:skill-runtime
# Health: /health
#
# --- Render: ai-assistant-cognitive (subset; paste on that service) ---
# API_PUBLIC_URL=https://ai-assistant-462r.onrender.com
# AI_SERVICE_URL=https://ai-assistant-ai.onrender.com
# INTERNAL_SERVICE_TOKEN=same-as-gateway
# NVIDIA_API_KEY=
# POLLINATIONS_API_KEY=
# GROQ_API_KEY=

# --- Render: ai-assistant-ai (subset; paste on that service) ---
# QDRANT_URL=https://CLUSTER_ID.region.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=
# NVIDIA_API_KEY=
# POLLINATIONS_API_KEY=
# GROQ_API_KEY=

QDRANT_URL=https://YOUR_CLUSTER.region.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=

NVIDIA_API_KEY=
GROQ_API_KEY=
POLLINATIONS_API_KEY=

VOICE_MODE=classic
VOICE_STT_PROVIDER=batch
OTEL_ENABLED=false

NEXT_PUBLIC_API_URL=https://ai-assistant-462r.onrender.com

# Expo push (gateway). Create at https://expo.dev/settings/access-tokens
EXPO_ACCESS_TOKEN=
